<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="onecore_mail_extension.Message" t-inherit="mail.Message" t-inherit-mode="extension">
        <!-- Add "(via sms)" / "(via mejl)" indicator in message header -->
        <xpath expr="//div[hasclass('o-mail-Message-header')]//small" position="inside">
            <span t-if="!isSendFailure()" t-esc="getSentAsString()" />
            <span t-if="isSendFailure()" class="text-danger fw-bold ms-1">
                <i class="fa fa-exclamation-triangle me-1" />
                <t t-esc="getSentAsString()" />
            </span>
        </xpath>

        <!-- Add t-ref for collapse height measurement -->
        <xpath expr="//div[hasclass('o-mail-Message')]" position="attributes">
            <attribute name="t-ref">messageRef</attribute>
        </xpath>

        <!-- Add collapse toggle button inside message root -->
        <xpath expr="//div[hasclass('o-mail-Message')]" position="inside">
            <button t-if="isCollapsible" class="toggle" t-on-click="toggleIsCollapsed">
                <i t-if="isCollapsed" class="oi oi-arrow-down"/>
                <i t-else="" class="oi oi-arrow-up"/>
            </button>
        </xpath>
    </t>
</templates>
