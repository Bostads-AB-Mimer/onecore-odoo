<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="maintenance_team_kanban_extension" model="ir.ui.view">
        <field name="name">maintenance.team.kanban.extension</field>
        <field name="model">maintenance.team</field>
        <field name="inherit_id" ref="maintenance.maintenance_team_kanban"/>
        <field name="arch" type="xml">
            <!-- Add the new field to the view -->
            <xpath expr="//field[@name='todo_request_count_unscheduled']" position="after">
                <field name="first_column_request_count"/>
            </xpath>

            <!-- Replace the "Scheduled" link with our custom "Väntar på handläggning" count -->
            <xpath expr="//a[descendant::field[@name='todo_request_count_date']]" position="replace">
                <a t-if="record.first_column_request_count.raw_value > 0"
                   name="%(maintenance.hr_equipment_todo_request_action_from_dashboard)d"
                   type="action" class="d-block">
                    <field name="first_column_request_count"/>
                    Väntar på handläggning
                </a>
            </xpath>

            <!-- Remove the "Unscheduled" link from the dashboard -->
            <xpath expr="//a[descendant::field[@name='todo_request_count_unscheduled']]" position="replace">
            </xpath>
        </field>
    </record>
</odoo>
